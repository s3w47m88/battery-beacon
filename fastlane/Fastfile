  app_store_connect_api_key(
    key_id: "XG3FW9LT9Q",
    issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"),
    in_house: false
  )
end

platform :mac do
  lane :wait_app do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    deadline = Time.now + (40 * 60)
    loop do
      app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon") rescue nil
      if app
        UI.success("WAITAPP FOUND id=#{app.id} name=#{app.name}")
        break
      end
      if Time.now > deadline
        UI.user_error!("WAITAPP TIMEOUT: app record not created within window")
      end
      UI.message("WAITAPP still waiting for app record…")
      sleep 20
    end
  end

  lane :wait_build do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    deadline = Time.now + (40 * 60)
    loop do
      build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
      if build
        UI.message("WAITBUILD #{build.version}: #{build.processing_state}")
        if build.processing_state == "VALID"
          UI.success("WAITBUILD READY #{build.version} (build #{build.id})")
          break
        end
      else
        UI.message("WAITBUILD no build visible yet…")
      end
      UI.user_error!("WAITBUILD TIMEOUT") if Time.now > deadline
      sleep 30
    end
  end

  lane :bb_diag do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    c = Spaceship::ConnectAPI.tunes_request_client
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    UI.message("DIAG app=#{app.id}")
    v = app.get_edit_app_store_version(platform: "MAC_OS")
    UI.message("DIAG version=#{v.version_string} state=#{v.app_store_state}")
    loc = Spaceship::ConnectAPI.get_app_store_version_localizations(app_store_version_id: v.id).to_models.find { |l| l.locale == "en-US" }
    UI.message("DIAG loc desc?=#{!loc.description.to_s.empty?} kw?=#{!loc.keywords.to_s.empty?} support?=#{!loc.support_url.to_s.empty?} whatsNew=#{loc.whats_new.inspect[0..40]}")
    begin
      ps = c.get("v1/apps/#{app.id}/appPriceSchedule")
      UI.message("DIAG priceSchedule=#{ps.body.inspect[0..200]}")
    rescue => e
      UI.message("DIAG priceSchedule ERR #{e.message[0..160]}")
    end
    begin
      pub = c.get("v1/apps/#{app.id}/dataUsagesPublishState")
      UI.message("DIAG privacyPublish=#{pub.body.inspect[0..200]}")
    rescue => e
      UI.message("DIAG privacyPublish ERR #{e.message[0..160]}")
    end
  end

  lane :bb_pricing do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    c = Spaceship::ConnectAPI.tunes_request_client
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")

    # Find the free (0.00) price point for the base territory USA.
    free_pp = nil
    %w[v1 v2].each do |ver|
      begin
        resp = c.get("#{ver}/apps/#{app.id}/appPricePoints", { "filter[territory]" => "USA", "limit" => 200 })
        pts = resp.body["data"] || []
        free_pp = pts.find { |p| ["0", "0.0", "0.00"].include?(p.dig("attributes", "customerPrice").to_s) }
        if free_pp
          UI.message("BBPRICE free price point (#{ver})=#{free_pp["id"]}")
          break
        else
          UI.message("BBPRICE #{ver}: #{pts.size} points, no free found; sample=#{pts.first&.dig("attributes")&.inspect&.slice(0,120)}")
        end
      rescue => e
        UI.message("BBPRICE #{ver} ERR #{e.message[0..160]}")
      end
    end
    UI.user_error!("No free price point found") unless free_pp

    body = {
      data: {
        type: "appPriceSchedules",
        relationships: {
          app: { data: { type: "apps", id: app.id } },
          baseTerritory: { data: { type: "territories", id: "USA" } },
          manualPrices: { data: [ { type: "appPrices", id: "${price1}" } ] }
        }
      },
      included: [
        {
          type: "appPrices",
          id: "${price1}",
          attributes: {},
          relationships: {
            appPricePoint: { data: { type: "appPricePoints", id: free_pp["id"] } }
          }
        }
      ]
    }
    resp = c.post("v1/appPriceSchedules", body)
    UI.success("BBPRICE schedule set: #{resp.body.dig("data", "id")}")
  end

  lane :bb_submit do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    version = app.get_edit_app_store_version(platform: "MAC_OS")
    en_v = Spaceship::ConnectAPI.get_app_store_version_localizations(app_store_version_id: version.id).to_models.find { |l| l.locale == "en-US" }

    existing = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id, filter: { state: "READY_FOR_REVIEW,WAITING_FOR_REVIEW,IN_REVIEW" }).to_models rescue []
    sub_id = existing.first&.id
    unless sub_id
      sub_resp = Spaceship::ConnectAPI.post_review_submission(app_id: app.id, platform: "MAC_OS")
      sub_id = sub_resp.to_models.first.id
    end
    items = Spaceship::ConnectAPI.get_review_submission_items(review_submission_id: sub_id).to_models rescue []
    if items.empty?
      Spaceship::ConnectAPI.post_review_submission_item(review_submission_id: sub_id, app_store_version_id: version.id)
    end
    # Dump screenshot states (correct relationship traversal).
    sets = Spaceship::ConnectAPI.get_app_screenshot_sets(app_store_version_localization_id: en_v.id, includes: "appScreenshots").to_models rescue []
    sets.each do |s|
      shots = s.app_screenshots || []
      UI.message("BBSUBMIT set #{s.screenshot_display_type}: #{shots.map { |sh| sh.asset_delivery_state&.dig('state') }.inspect}")
    end
    begin
      Spaceship::ConnectAPI.patch_review_submission(review_submission_id: sub_id, attributes: { submitted: true })
      UI.success("BBSUBMIT submitted sub=#{sub_id}")
    rescue Spaceship::UnexpectedResponse => e
      UI.error("BBSUBMIT detail: #{e.preferred_error_info.inspect}") if e.respond_to?(:preferred_error_info)
      UI.error("BBSUBMIT full: #{e.to_s}")
      raise
    end
    v2 = app.get_edit_app_store_version(platform: "MAC_OS") || app.get_latest_app_store_version(platform: "MAC_OS")
    UI.success("BBSUBMIT version #{v2.version_string} state=#{v2.app_store_state}")
  end

  lane :bb_wait_privacy do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    deadline = Time.now + (40 * 60)
    loop do
      begin
        st = Spaceship::ConnectAPI::AppDataUsagesPublishState.get(app_id: app.id)
        UI.message("BBWAITPRIV published=#{st&.published.inspect}")
        if st&.published
          UI.success("BBWAITPRIV PUBLISHED")
          break
        end
      rescue => e
        UI.message("BBWAITPRIV read err #{e.message[0..120]}")
      end
      UI.user_error!("BBWAITPRIV TIMEOUT") if Time.now > deadline
      sleep 20
    end
  end

  lane :bb_privacy do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    # Clear any existing data usages.
    (Spaceship::ConnectAPI.get_app_data_usages(app_id: app.id).to_models rescue []).each do |u|
      Spaceship::ConnectAPI.delete_app_data_usage(app_data_usage_id: u.id) rescue nil
    end
    # Declare "Data Not Collected".
    Spaceship::ConnectAPI.post_app_data_usage(
      app_id: app.id,
      app_data_usage_protection_id: Spaceship::ConnectAPI::AppDataUsageDataProtection::ID::DATA_NOT_COLLECTED
    )
    UI.success("BBPRIV declared DATA_NOT_COLLECTED")
    # Publish the privacy section.
    state = Spaceship::ConnectAPI::AppDataUsagesPublishState.get(app_id: app.id)
    UI.message("BBPRIV publish state id=#{state.id} published=#{state.published}")
    Spaceship::ConnectAPI.patch_app_data_usages_publish_state(app_data_usages_publish_state_id: state.id, published: true)
    UI.success("BBPRIV published")
  end

  lane :bb_diag2 do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(key_id: "XG3FW9LT9Q", issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d", filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"))
    Spaceship::ConnectAPI.token = token
    c = Spaceship::ConnectAPI.tunes_request_client
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    v = app.get_edit_app_store_version(platform: "MAC_OS")
    UI.message("D2 version=#{v.version_string} state=#{v.app_store_state} id=#{v.id}")
    loc = Spaceship::ConnectAPI.get_app_store_version_localizations(app_store_version_id: v.id).to_models.find { |l| l.locale == "en-US" }
    # screenshots via raw GET
    ss = c.get("v1/appStoreVersionLocalizations/#{loc.id}/appScreenshotSets", { "include" => "appScreenshots" })
    sets = ss.body["data"] || []
    incl = ss.body["included"] || []
    UI.message("D2 screenshotSets=#{sets.size} screenshots=#{incl.size}")
    incl.each { |s| UI.message("D2 shot #{s["id"]} state=#{s.dig("attributes","assetDeliveryState","state")}") }
    # pricing
    begin
      ps = c.get("v1/appPriceSchedules/#{app.id}/manualPrices", { "include" => "appPricePoint", "limit" => 5 })
      UI.message("D2 manualPrices=#{(ps.body["data"]||[]).size}")
    rescue => e
      UI.message("D2 manualPrices ERR #{e.message[0..160]}")
    end
    # privacy publish state
    ["v1/apps/#{app.id}/relationships/dataUsagesPublishState", "v2/apps/#{app.id}/appDataUsagesPublishState"].each do |p|
      begin
        r = c.get(p)
        UI.message("D2 #{p} => #{r.body.inspect[0..200]}")
      rescue => e
        UI.message("D2 #{p} ERR #{e.message[0..120]}")
      end
    end
    # data usages count
    begin
      du = Spaceship::ConnectAPI.get_app_data_usages(app_id: app.id).to_models
      UI.message("D2 dataUsages=#{du.size}")
    rescue => e
      UI.message("D2 dataUsages ERR #{e.message[0..120]}")
    end
  end

  desc "Create app record in App Store Connect via Spaceship"
  lane :create_app do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token

    bundle_id = "com.spencerhill.batterybeacon"
    existing_bid = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bundle_id }).first
    if existing_bid
      UI.message("Bundle ID #{bundle_id} already registered")
    else
      UI.message("Registering bundle ID #{bundle_id}")
      Spaceship::ConnectAPI::BundleId.create(
        name: "Battery Beacon",
        platform: Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS,
        identifier: bundle_id
      )
    end

    existing_app = Spaceship::ConnectAPI::App.find(bundle_id)
    if existing_app
      UI.success("App already exists: #{existing_app.name} (id=#{existing_app.id})")
    else
      UI.message("Creating ASC app record")
      app = Spaceship::ConnectAPI::App.create(
        name: "Battery Beacon",
        version_string: "0.1.0",
        sku: "batterybeacon001",
        primary_locale: "en-US",
        bundle_id: bundle_id,
        platforms: [Spaceship::ConnectAPI::Platform::MAC_OS]
      )
      UI.success("Created: #{app.name} (id=#{app.id})")
    end
  end

  desc "Set up App Store metadata and submit for public release review"
  lane :release do
    require 'spaceship'
    require 'digest'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.batterybeacon")
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("App: #{app.id}, Build: #{build.version} (#{build.processing_state})")

    # 1) Pricing — Free (tier "0")
    begin
      Spaceship::ConnectAPI.patch_app(app_id: app.id, app_price_tier_id: "0")
      UI.success("Pricing: Free (tier 0)")
    rescue => e
      UI.message("pricing: #{e.message[0..300]}")
    end

    # 2) App Info — primary category + content rights
    app_info = app.fetch_edit_app_info || app.fetch_latest_app_info
    UI.message("App info: #{app_info.id} state=#{app_info.app_store_state}")
    begin
      Spaceship::ConnectAPI.patch_app(app_id: app.id, attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
      UI.success("Content rights declaration set on app")
    rescue => e
      UI.message("content rights: #{e.message[0..300]}")
    end
    begin
      Spaceship::ConnectAPI.patch_app_info_categories(app_info_id: app_info.id, category_id_map: { primary_category_id: "UTILITIES" })
    rescue => e
      UI.message("category: #{e.message[0..200]}")
    end

    # 3) App Info Localization — name, subtitle, privacy policy URL
    info_locs = Spaceship::ConnectAPI.get_app_info_localizations(app_info_id: app_info.id).to_models
    en_loc = info_locs.find { |l| l.locale == "en-US" }
    if en_loc
      Spaceship::ConnectAPI.patch_app_info_localization(app_info_localization_id: en_loc.id, attributes: {
        name: "Battery Beacon",
        subtitle: "Battery-percentage alerts",
        privacyPolicyUrl: "https://github.com/s3w47m88/battery-beacon"
      }) rescue UI.message("info loc: #{$!.message[0..120]}")
      UI.success("App info localization updated")
    end

    # 4) App Store version — get or create
    desired_version = ENV["RELEASE_VERSION"] || "0.1.2"
    version = app.get_edit_app_store_version(platform: "MAC_OS")
    if version.nil?
      UI.message("No editable version; creating #{desired_version}")
      resp = Spaceship::ConnectAPI.post_app_store_version(
        app_id: app.id,
        attributes: { platform: "MAC_OS", versionString: desired_version, releaseType: "AFTER_APPROVAL", copyright: "2026 Spencer Hill" }
      )
      version = resp.to_models.first
    elsif version.version_string != desired_version
      UI.message("Updating editable version #{version.version_string} -> #{desired_version}")
      Spaceship::ConnectAPI.patch_app_store_version(app_store_version_id: version.id, attributes: { versionString: desired_version }) rescue UI.message("version rename: #{$!.message[0..200]}")
    end
    UI.message("Version: #{version&.version_string} state=#{version&.app_store_state}")

    # 5) Version localization — description, keywords, support URL, what's new
    locs = Spaceship::ConnectAPI.get_app_store_version_localizations(app_store_version_id: version.id).to_models
    en_v = locs.find { |l| l.locale == "en-US" }
    # Required localization fields — patched on their own so the whole request
    # is not rejected when an optional field (whatsNew) is disallowed on a
    # first version of a brand-new app.
    Spaceship::ConnectAPI.patch_app_store_version_localization(app_store_version_localization_id: en_v.id, attributes: {
      description: "Battery Beacon is a tiny menu bar utility that notifies you the moment your Mac's battery reaches the percentage you choose — so you can unplug at 95%, 100%, or any threshold you set, and never overcharge.\n\nFeatures:\n• Lives in the menu bar; shows current battery % and a charging bolt.\n• Configurable alert thresholds with sliders (default 95% and 100%).\n• Native macOS notifications fire near the battery icon at each threshold while plugged in.\n• Optional alert sound.\n• Thresholds reset automatically when you unplug — one alert per threshold per charge cycle.\n• Built with SwiftUI; respects your system theme, including Liquid Glass on macOS 26.",
      keywords: "battery,alert,charge,menu bar,notification,utility,laptop,macbook",
      supportUrl: "https://github.com/s3w47m88/battery-beacon",
      marketingUrl: "https://github.com/s3w47m88/battery-beacon",
      promotionalText: "Never overcharge your Mac again."
    }) rescue UI.message("version loc: #{$!.message[0..200]}")
    # whatsNew is only valid on updates (not a first version); attempt separately.
    Spaceship::ConnectAPI.patch_app_store_version_localization(app_store_version_localization_id: en_v.id, attributes: {
      whatsNew: "Refreshed App Store screenshots to better reflect the actual app."
    }) rescue UI.message("whatsNew (expected to fail on first version): #{$!.message[0..120]}")
    UI.success("Version localization updated")

    # 6) Version attributes — copyright, release type
    Spaceship::ConnectAPI.patch_app_store_version(app_store_version_id: version.id, attributes: {
      copyright: "2026 Spencer Hill",
      releaseType: "AFTER_APPROVAL"
    }) rescue UI.message("version attrs: #{$!.message[0..200]}")

    # 7) Attach build to version
    begin
      Spaceship::ConnectAPI.patch_app_store_version_with_build(app_store_version_id: version.id, build_id: build.id)
      UI.success("Build attached to version")
    rescue => e
      UI.message("build link: #{e.message[0..200]}")
    end

    # 8) Screenshot upload — replace all existing with current *-store.png files
    begin
      require 'net/http'
      sets = Spaceship::ConnectAPI.get_app_screenshot_sets(app_store_version_localization_id: en_v.id).to_models
      desktop_sets = sets.select { |s| s.screenshot_display_type == "APP_DESKTOP" }
      desktop_sets.each do |set|
        Spaceship::ConnectAPI.delete_app_screenshot_set(app_screenshot_set_id: set.id) rescue UI.message("del set fail: #{$!.message[0..200]}")
      end
      resp = Spaceship::ConnectAPI.post_app_screenshot_set(app_store_version_localization_id: en_v.id, attributes: { screenshotDisplayType: "APP_DESKTOP" })
      mac_set = resp.to_models.first
      files = Dir[File.expand_path("screenshots/en-US/*-store.png", __dir__)].sort
      files.each do |file|
        bytes = File.binread(file)
        resp = Spaceship::ConnectAPI.post_app_screenshot(app_screenshot_set_id: mac_set.id, attributes: { fileName: File.basename(file), fileSize: bytes.bytesize })
        upload = resp.to_models.first
        op = upload.upload_operations.first
        headers = {}
        op["requestHeaders"].each { |h| headers[h["name"]] = h["value"] }
        uri = URI(op["url"])
        http = Net::HTTP.new(uri.host, uri.port); http.use_ssl = (uri.scheme == "https")
        klass = Net::HTTP.const_get(op["method"].capitalize)
        req = klass.new(uri.request_uri)
        headers.each { |k,vv| req[k] = vv }
        req.body = bytes
        http.request(req)
        Spaceship::ConnectAPI.patch_app_screenshot(app_screenshot_id: upload.id, attributes: { uploaded: true, sourceFileChecksum: Digest::MD5.hexdigest(bytes) })
        UI.message("uploaded #{File.basename(file)}")
      end
      UI.success("Screenshots replaced (#{files.size})")
    rescue => e
      UI.error("screenshot upload: #{e.message[0..400]}")
    end

    # 8.5) App Privacy — declare "No data collected" and publish
    begin
      # First clear existing data usages (declare nothing collected)
      usages = Spaceship::ConnectAPI.get_app_data_usages(app_id: app.id).to_models rescue []
      usages.each { |u| Spaceship::ConnectAPI.delete_app_data_usage(app_data_usage_id: u.id) rescue nil }
      # Publish via dataUsagesPublishState
      body = { data: { type: "appDataUsagesPublishState", attributes: { published: true } } }
      Spaceship::ConnectAPI.tunes_request_client.patch("v1/apps/#{app.id}/relationships/dataUsagesPublishState", body) rescue nil
      # Alternative path
      Spaceship::ConnectAPI.tunes_request_client.patch("v1/apps/#{app.id}/dataUsagesPublishState", body) rescue nil
      UI.success("App privacy: published (no data collected)")
    rescue => e
      UI.message("app privacy: #{e.message[0..300]}")
    end

    # 9) Age rating — set every required category to NONE/false
    begin
      ard_resp = Spaceship::ConnectAPI.get_age_rating_declaration(app_info_id: app_info.id)
      ard = ard_resp.to_models.first
      base_attrs = {
        violenceCartoonOrFantasy: "NONE", violenceRealistic: "NONE",
        profanityOrCrudeHumor: "NONE", matureOrSuggestiveThemes: "NONE", horrorOrFearThemes: "NONE",
        medicalOrTreatmentInformation: "NONE", alcoholTobaccoOrDrugUseOrReferences: "NONE",
        gamblingSimulated: "NONE", sexualContentOrNudity: "NONE", sexualContentGraphicAndNudity: "NONE",
        gunsOrOtherWeapons: "NONE",
        contests: "NONE", gambling: false, unrestrictedWebAccess: false, kidsAgeBand: nil,
        lootBox: false, advertising: "NONE", drugsAlcoholOrTobaccoUse: "NONE"
      }
      # Discover any other required keys by retrying
      base_attrs[:parentalControls] = false
      base_attrs[:advertising] = false
      base_attrs.delete(:drugsAlcoholOrTobaccoUse)
      done = false
      12.times do
        begin
          Spaceship::ConnectAPI.patch_age_rating_declaration(age_rating_declaration_id: ard.id, attributes: base_attrs)
          UI.success("Age rating set with #{base_attrs.keys.size} fields")
          done = true
          break
        rescue => e
          msg = e.message[0..800]
          UI.message("age rating err: #{msg}")
          changed = false
          msg.scan(/required attribute.*?'(\w+)'/).flatten.each do |missing|
            unless base_attrs.key?(missing.to_sym)
              base_attrs[missing.to_sym] = (missing =~ /^(gambling|lootBox|unrestrictedWebAccess|parentalControls|advertising|seventeenPlus)$/) ? false : "NONE"
              changed = true
            end
          end
          msg.scan(/wrong type.*?attribute '(\w+)'.*?Expected a BOOLEAN/).flatten.each do |bool_attr|
            base_attrs[bool_attr.to_sym] = false
            changed = true
          end
          msg.scan(/unknown attribute.*?'(\w+)'/).flatten.each do |unknown|
            if base_attrs.delete(unknown.to_sym)
              changed = true
            end
          end
          break unless changed
        end
      end
      UI.message("Age rating skipped — could not converge") unless done
    rescue => e
      UI.message("age rating outer: #{e.message[0..300]}")
    end

    # 10) App Store review detail — contact + demo (create if missing)
    begin
      detail = nil
      begin
        detail = version.fetch_app_store_review_detail
      rescue
      end
      attrs = {
        contactFirstName: "Spencer", contactLastName: "Hill",
        contactEmail: "thespencerhill@gmail.com", contactPhone: "5035550100",
        demoAccountRequired: false,
        notes: "Menu bar utility. Click the menu bar battery percentage to open settings. No login. To test alerts, plug in the Mac while the app is running; notifications fire as battery crosses configured thresholds (default 95% and 100%)."
      }
      if detail
        Spaceship::ConnectAPI.patch_app_store_review_detail(app_store_review_detail_id: detail.id, attributes: attrs)
      else
        Spaceship::ConnectAPI.post_app_store_review_detail(app_store_version_id: version.id, attributes: attrs)
      end
      UI.success("Review contact set")
    rescue => e
      UI.message("review detail: #{e.message[0..400]}")
    end

    # 11) Submit for review using new reviewSubmissions API
    begin
      # Reuse existing IN_PROGRESS submission if present
      existing = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id, filter: { state: "READY_FOR_REVIEW,WAITING_FOR_REVIEW,IN_REVIEW" }).to_models rescue []
      sub_id = existing.first&.id
      unless sub_id
        existing_ready = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id).to_models
        in_prog = existing_ready.find { |s| s.state == "READY_FOR_REVIEW" }
        sub_id = in_prog&.id
      end
      unless sub_id
        sub_resp = Spaceship::ConnectAPI.post_review_submission(app_id: app.id, platform: "MAC_OS")
        sub_id = sub_resp.to_models.first.id
      end
      UI.message("Review submission: #{sub_id}")
      # Add item (if not already)
      items = Spaceship::ConnectAPI.get_review_submission_items(review_submission_id: sub_id).to_models rescue []
      if items.empty?
        Spaceship::ConnectAPI.post_review_submission_item(review_submission_id: sub_id, app_store_version_id: version.id)
        UI.message("Added version as submission item")
      else
        UI.message("Submission already has #{items.size} item(s)")
      end
      Spaceship::ConnectAPI.patch_review_submission(review_submission_id: sub_id, attributes: { submitted: true })
      UI.success("Submitted for App Store review")
    rescue => e
      UI.error("Submit failed: #{e.message[0..600]}")
    end
  end

